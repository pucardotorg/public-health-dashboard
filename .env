# ============================================================================
# Shared defaults — loaded in EVERY mode (dev / uat / prod).
# Only non-secret, public configuration lives here. Mode-specific files
# (.env.development, .env.uat, .env.production) override these values.
# Personal overrides: create .env.local (git-ignored).
# ============================================================================

# Path to the backend health-status endpoint. Same across all environments.
VITE_HEALTH_STATUS_PATH=/health-dashboard/v1/services/status

# API origin. Empty string = same-origin (relative request).
# Recommended: leave empty when the dashboard is served on the SAME host as the
# API in each environment — the browser then calls the API relative to whatever
# host it's loaded from, so no per-environment change and no CORS.
# Set an absolute origin (e.g. https://dristi-kerala-dev.pucar.org) ONLY if the
# dashboard is hosted on a different domain than the API (requires backend CORS).
VITE_API_BASE_URL=

# How often (ms) the UI re-fetches the status while the page is open.
# Default 3 minutes. Set to 0 to disable polling (fetch only on page load).
VITE_REFRESH_INTERVAL_MS=180000
