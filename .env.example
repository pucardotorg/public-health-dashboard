# ============================================================================
# Template of all environment variables this app reads. Copy any you need to
# override into .env.local (git-ignored). All values are VITE_-prefixed so
# they are exposed to the client bundle — never put secrets here.
# ============================================================================

# Backend health-status endpoint path (same in all environments).
VITE_HEALTH_STATUS_PATH=/health-dashboard/v1/services/status

# API origin. Empty = same-origin (recommended). Set an absolute origin only
# for cross-origin hosting (requires backend CORS), e.g.:
#   VITE_API_BASE_URL=https://dristi-kerala-dev.pucar.org
VITE_API_BASE_URL=

# LOCAL DEV ONLY: backend that `npm run dev` proxies /health-dashboard/* to.
VITE_DEV_API_TARGET=https://dristi-kerala-dev.pucar.org
