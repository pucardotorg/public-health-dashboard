# ============================================================================
# UAT environment — used by `npm run build:uat` (Vite mode: uat).
# Maps to the `main` branch deployed to UAT for testing before prod.
# ============================================================================

# Same-origin in UAT (dashboard served on the same host as the API).
# If UAT hosts the API on a different domain, set the absolute origin here
# and ensure the backend allows CORS from the dashboard's host.
VITE_API_BASE_URL=
